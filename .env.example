# ─── Database ─────────────────────────────────────────────────
# Local PostgreSQL (Docker): postgresql://user:password@localhost:5432/todoapp
# Supabase (Vercel): uses POSTGRES_PRISMA_URL from integration — leave this blank
DATABASE_URL="postgresql://user:password@localhost:5432/todoapp"

# ─── Authentication (NextAuth v5) ────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# ─── NextAuth Trust (local dev only) ─────────────────────────
# Set to "true" for local development; remove in production
AUTH_TRUST_HOST="true"
